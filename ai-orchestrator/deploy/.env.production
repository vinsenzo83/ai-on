# ============================================================
# AI Orchestrator — .env.production 템플릿
# 복사 방법: cp .env.production .env
# 생성일: 2026-03-11
# ============================================================

# ─────────────────────────────────────────────────────────
# 서버 설정
# ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─────────────────────────────────────────────────────────
# JWT 보안 (반드시 강력한 랜덤 값으로 교체!)
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES=24h

# ─────────────────────────────────────────────────────────
# 어드민 계정 (초기 접속 후 UI에서 변경 권장)
# ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─────────────────────────────────────────────────────────
# CORS 허용 도메인 (쉼표 구분, 빈칸=전체 허용)
# ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─────────────────────────────────────────────────────────
# AI 공급자 API 키
# ─────────────────────────────────────────────────────────

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy...
GEMINI_API_KEY=AIzaSy...

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# xAI (Grok): https://console.x.ai/
XAI_API_KEY=xai-...

# Moonshot (Kimi): https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-...

# Mistral AI: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# Groq (선택): https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (선택): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────
# 기본 모델 설정 (공급자 키 설정 후 변경 권장)
# ─────────────────────────────────────────────────────────
DEFAULT_TEXT_MODEL=gpt-4o
DEFAULT_ANALYSIS_MODEL=gpt-4o
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_CODE_MODEL=gpt-4o
DEFAULT_CREATIVE_MODEL=gpt-4o
DEFAULT_FAST_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Redis (선택 - 없으면 인메모리 큐 사용)
# ─────────────────────────────────────────────────────────
REDIS_URL=

# ─────────────────────────────────────────────────────────
# 로깅
# ─────────────────────────────────────────────────────────
LOG_LEVEL=info
