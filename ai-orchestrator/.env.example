# AI 오케스트레이터 환경변수 설정
# 이 파일을 .env로 복사 후 값을 채워주세요: cp .env.example .env

# ─────────────────────────────────────────────────────────
# 서버 설정
# ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─────────────────────────────────────────────────────────
# JWT 보안 설정 (반드시 강력한 랜덤 값으로 교체!)
# 생성 방법: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES=24h

# ─────────────────────────────────────────────────────────
# 어드민 계정 (초기 설정 후 변경 권장)
# ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# ─────────────────────────────────────────────────────────
# AI 공급자 API 키
# ─────────────────────────────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic Claude: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy...
GEMINI_API_KEY=AIzaSy...

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# xAI (Grok): https://console.x.ai/
XAI_API_KEY=xai-...

# Moonshot (Kimi): https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-...

# Mistral AI: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# Groq (선택): https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenRouter (선택): https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ─────────────────────────────────────────────────────────
# 기본 모델 설정
# ─────────────────────────────────────────────────────────
DEFAULT_TEXT_MODEL=gpt-4o
DEFAULT_ANALYSIS_MODEL=gpt-4o
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_CODE_MODEL=gpt-4o
DEFAULT_CREATIVE_MODEL=gpt-4o
DEFAULT_FAST_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Redis (작업 큐 - 선택사항)
# Docker Compose 사용시: redis://redis:6379
# ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────
# 외부 서비스 (선택사항)
# ─────────────────────────────────────────────────────────
# SendGrid (이메일 알림)
# SENDGRID_API_KEY=SG....

# AWS S3 (파일 저장)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=...

# Slack (알림)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
