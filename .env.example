# =============================================================================
# KBeauty AutoCommerce — 환경변수 예시 파일
# =============================================================================
# 복사 방법: cp .env.example .env
# 모든 <CHANGE_ME> 값은 실제 운영 전 반드시 변경하세요.
#
# 레이어별 항목:
#   [APP]       기본 앱 설정
#   [DB]        PostgreSQL 데이터베이스
#   [REDIS]     Redis / Celery 브로커
#   [JWT]       인증/권한 (Admin API)
#   [SHOPIFY]   Shopify 연동 (Sprint 1~12)
#   [SUPPLIER]  공급사 크롤러 (Sprint 2, 7)
#   [CHANNELS]  멀티채널 (Sprint 9 — Shopee, TikTok)
#   [CRAWL]     상품 크롤링 인터벌
#   [STORAGE]   파일 저장 경로
#   [TRACKING]  배송 추적 폴링
#   [PRICING]   가격 동기화
#   [WEBHOOK]   웹훅 서명 검증
#   [PHASE14]   모듈 실행 레이어 설정
#   [PHASE15]   일반 도구 레이어 설정
#   [PHASE16]   개발자 도구 레이어 설정
#   [PHASE17]   워크플로우 오케스트레이션 설정
#   [DASHBOARD] Next.js 대시보드 설정
#   [AI-ORCH]   Node.js AI 오케스트레이터 (ai-orchestrator/)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# [APP] 기본 앱 설정
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development
# production | staging | development
DEBUG=false
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR

# ─────────────────────────────────────────────────────────────────────────────
# [DB] PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=kbeauty
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_HOST=localhost
# Docker Compose 환경: postgres
POSTGRES_PORT=5432
POSTGRES_DB=kbeauty

# CI / 테스트 전용 — 설정 시 POSTGRES_* 대신 사용됨 (프로덕션은 비워둘 것)
DATABASE_URL_TEST=

# ─────────────────────────────────────────────────────────────────────────────
# [REDIS] Redis / Celery 브로커
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
# Docker Compose 환경: redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# 운영 환경에서는 반드시 비밀번호 설정

# ─────────────────────────────────────────────────────────────────────────────
# [JWT] Admin API 인증 (Sprint 5+)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=<CHANGE_ME_USE_openssl_rand_hex_32>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# 8시간; 운영 환경에서는 더 짧게 설정 권장 (예: 60)

# 기본 관리자 계정 (최초 부팅 / 시드용 — 운영 시 DB 계정으로 교체)
ADMIN_EMAIL=admin@kbeauty.local
ADMIN_PASSWORD=<CHANGE_ME>

# ─────────────────────────────────────────────────────────────────────────────
# [WEBHOOK] 웹훅 서명 검증 (Sprint 11)
# ─────────────────────────────────────────────────────────────────────────────
WEBHOOK_VERIFY=false
# 운영 환경: true

# ─────────────────────────────────────────────────────────────────────────────
# [SHOPIFY] Shopify 연동 (Sprint 1~12)
# ─────────────────────────────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=<CHANGE_ME>
SHOPIFY_API_KEY=<CHANGE_ME>
SHOPIFY_API_SECRET=<CHANGE_ME>
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=<CHANGE_ME>
# Shopify Admin API Access Token (Private App)

# ─────────────────────────────────────────────────────────────────────────────
# [SUPPLIER] 공급사 크롤러 (Sprint 2, 7)
# ─────────────────────────────────────────────────────────────────────────────
STYLEKOREAN_EMAIL=<CHANGE_ME>
STYLEKOREAN_PASSWORD=<CHANGE_ME>
STYLEKOREAN_BASE_URL=https://www.stylekorean.com
STORAGE_PATH=./storage
# 봇 실패 아티팩트 저장 경로 (스크린샷, HTML 덤프)

# ─────────────────────────────────────────────────────────────────────────────
# [CRAWL] 상품 크롤링 인터벌 (Sprint 4)
# ─────────────────────────────────────────────────────────────────────────────
PRODUCT_CRAWL_LIMIT=500
PRODUCT_CRAWL_INTERVAL=43200
# 12시간 (초 단위)
PRODUCT_SYNC_INTERVAL=1800
# 30분

# ─────────────────────────────────────────────────────────────────────────────
# [TRACKING] 배송 추적 (Sprint 3)
# ─────────────────────────────────────────────────────────────────────────────
TRACKING_POLL_INTERVAL=600
# 10분 (초 단위)

# ─────────────────────────────────────────────────────────────────────────────
# [PRICING] 가격 동기화 (Sprint 8)
# ─────────────────────────────────────────────────────────────────────────────
PRICING_SYNC_INTERVAL=21600
# 6시간
MARGIN_GUARD_PCT=15.0
# 마진 경고 임계값 (%)
SUPPLIER_COST_RATIO=0.75
# 공급가 추정 비율 (공급가 / 소매가)

# ─────────────────────────────────────────────────────────────────────────────
# [CHANNELS] 멀티채널 동기화 (Sprint 9)
# ─────────────────────────────────────────────────────────────────────────────
CHANNEL_PUBLISH_INTERVAL=43200
# 12시간
CHANNEL_PRICE_INTERVAL=21600
# 6시간
CHANNEL_INVENTORY_INTERVAL=3600
# 1시간
CHANNEL_ORDERS_INTERVAL=900
# 15분
SUPPLIER_SYNC_INTERVAL=3600
# 1시간
INVENTORY_SYNC_INTERVAL=1800
# 30분

# Shopee 채널
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=

# TikTok Shop 채널
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SHOP_ID=
TIKTOK_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# [PHASE14] 모듈 실행 레이어 (Phase 14)
# ─────────────────────────────────────────────────────────────────────────────
# ModuleExecutor는 ProviderRunner를 주입받아 실행합니다.
# 운영 환경에서는 실제 LLM 프로바이더 연동 필요.
# 현재 기본값: MockProviderRunner (테스트/개발용)
#
# (향후 연동 시 추가 예정 변수)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# DEFAULT_MODEL=gpt-4o
# FALLBACK_MODEL=gpt-3.5-turbo
MODULE_MOCK_OUTPUT=Module executed successfully.
# MockProviderRunner 기본 응답값 (테스트/개발용)

# ─────────────────────────────────────────────────────────────────────────────
# [PHASE15] 일반 도구 레이어 (Phase 15) — /tools API
# ─────────────────────────────────────────────────────────────────────────────
# 등록 도구: search, pdf, ocr, email, image, browser
# 현재 모든 도구는 Mock 모드로 동작 (외부 API 키 없이 실행 가능)
#
# 실제 연동 시 추가 예정 변수:
# SEARCH_API_KEY=                   # 검색 도구 외부 API 키
# BROWSER_HEADLESS=true             # Playwright 헤드리스 모드
# EMAIL_SMTP_HOST=                  # 이메일 도구 SMTP 서버
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
# OCR_PROVIDER=local                # local | google | azure
# OCR_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# [PHASE16] 개발자 도구 레이어 (Phase 16) — /devtools API
# ─────────────────────────────────────────────────────────────────────────────
# 등록 도구 18종: repo_search, filesystem, code_patch, terminal,
#   test_runner, git, playwright_browser, lint_format, dependency,
#   log_reader, build_tool, env_config, migration, preview,
#   workflow, deploy_helper, doc_export, sandbox_run
#
# 모드 게이트: read_only (VIEWER) / safe_write (OPERATOR) / full (ADMIN)
# workspace_root는 각 API 요청의 params에 포함
#
# 실제 연동 시 추가 예정 변수:
# DEVTOOLS_DEFAULT_WORKSPACE=/workspace
# DEVTOOLS_SANDBOX_TIMEOUT=30       # sandbox_run 최대 실행시간 (초)
# DEVTOOLS_MAX_FILE_SIZE_MB=10      # filesystem 단일 파일 최대 크기

# ─────────────────────────────────────────────────────────────────────────────
# [PHASE17] 워크플로우 오케스트레이션 (Phase 17) — /orchestration API
# ─────────────────────────────────────────────────────────────────────────────
# 지원 워크플로우 8종:
#   website_analysis, document_pdf, search_summary,
#   devtool_code, devtool_document, browser_extract,
#   generic, pipeline
#
# 현재 기본 실행기: MockProviderRunner (실제 LLM 없이 동작)
# ORCHESTRATION_MAX_PIPELINE_STEPS=10
# ORCHESTRATION_DEFAULT_WORKFLOW=generic

# ─────────────────────────────────────────────────────────────────────────────
# [DASHBOARD] Next.js 대시보드 (dashboard/)
# ─────────────────────────────────────────────────────────────────────────────
# 파일 위치: dashboard/.env.local (Next.js 표준)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Python FastAPI 백엔드 URL (브라우저에서 직접 호출)

NEXT_PUBLIC_AI_ORCHESTRATOR_URL=http://localhost:9000
# Node.js AI 오케스트레이터 URL (Phase 16 대시보드용)

# Next.js 빌드 설정
# PORT=3001 (dashboard/package.json에 고정: next dev -p 3001)

# ─────────────────────────────────────────────────────────────────────────────
# [AI-ORCH] Node.js AI 오케스트레이터 (ai-orchestrator/)
# ─────────────────────────────────────────────────────────────────────────────
# 파일 위치: ai-orchestrator/.env (ai-orchestrator/.env.example 참조)
AI_ORCH_PORT=9000
AI_ORCH_NODE_ENV=production
# development | production

AI_ORCH_DB_PATH=./data/orchestrator.db
# SQLite DB 경로 (ai-orchestrator 내부)

AI_ORCH_JWT_SECRET=<CHANGE_ME_USE_openssl_rand_hex_32>
AI_ORCH_JWT_EXPIRE_HOURS=8

# LLM 프로바이더 API 키 (ai-orchestrator용)
AI_ORCH_OPENAI_API_KEY=sk-<CHANGE_ME>
AI_ORCH_ANTHROPIC_API_KEY=<CHANGE_ME>
AI_ORCH_GOOGLE_API_KEY=<CHANGE_ME>

# 모델 기본값
AI_ORCH_DEFAULT_PROVIDER=openai
AI_ORCH_DEFAULT_MODEL=gpt-4o
AI_ORCH_FALLBACK_MODEL=gpt-3.5-turbo

# Python 백엔드 연동
AI_ORCH_PYTHON_API_URL=http://localhost:8000
AI_ORCH_PYTHON_API_TOKEN=<내부통신용_JWT_또는_SHARED_SECRET>

# =============================================================================
# 서비스 포트 정리
# =============================================================================
# Python FastAPI (uvicorn)  : 8000  — app/main.py
# Celery Worker             : (포트 없음, Redis 브로커 사용)
# Node.js AI Orchestrator   : 9000  — ai-orchestrator/src/server.js
# Next.js Dashboard         : 3001  — dashboard/
# PostgreSQL                : 5432
# Redis                     : 6379
# =============================================================================
